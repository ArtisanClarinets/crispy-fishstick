{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "Remotion": {
      "type": "local",
      "command": [ 
        "npx",
        "-y",
        "@remotion/mcp@latest"
      ]
  },
      "opencode-tools": {
      "type": "local",
      "command": [
        "opencode-tools",
        "mcp"
      ],
      "enabled": true
    },
    "Memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory@latest"
      ],
      "enabled": true,
      "timeout": 5000
    },
    "critical-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-server-actor-critic-thinking"
      ],
      "enabled": true,
      "timeout": 15000
    },
    "Serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server"
      ],
      "enabled": true,
      "timeout": 15000
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true
    },
    "shadcn": {
      "type": "local",
      "command": [
        "npx",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true
    },
    "Desktop-Commander": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@wonderwhy-er/desktop-commander"
      ],
      "enabled": true
    },
    "next-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "next-devtools-mcp@latest"
      ],
      "enabled": true
    },
    "prisma-mcp-server": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "prisma",
        "mcp"
      ],
      "enabled": true
    },
    "Better Auth": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.inkeep.com/better-auth/mcp"
      ],
      "enabled": true
    },
    "Stripe": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.stripe.com"
      ],
      "enabled": true
    }
  },
  "permission": {
    "edit": "allow",
    "bash": {
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "ls*": "allow",
      "pwd": "allow",
      "echo *": "allow"
    },
    "write": "allow",
    "read": "allow"
  }
}
